# Copy to .env and fill in

# ---- GenLayer ----
# Bradbury Testnet (default):
GENLAYER_RPC_URL=https://rpc-bradbury.genlayer.com
# Localnet (for local development):
# GENLAYER_RPC_URL=http://localhost:4000/api
# Studionet (legacy):
# GENLAYER_RPC_URL=https://studio.genlayer.com/api

# Deployed Backstab Court contract address (from: node contract/deploy/deploy.ts)
CONTRACT_ADDRESS=0x...

# ---- Server ----
PORT=4100
CORS_ORIGIN=http://localhost:5173
# Server's own private key for signing contract transactions (auto-generated if not set)
# SERVER_PRIVATE_KEY=0x...

# ---- Web (Vite) ----
VITE_GENLAYER_RPC_URL=https://rpc-bradbury.genlayer.com
VITE_CONTRACT_ADDRESS=0x...
VITE_SERVER_URL=http://localhost:4100
